# StarParks客服系统 .gitignore

# 配置文件（敏感信息）
config/discord-bot.json
config/secrets.json
*.env
*.token

# 日志文件
logs/
*.log

# 数据文件
data/private/
data/temp/
*.db
*.sqlite

# 临时文件
*.tmp
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# 编辑器
.vscode/
.idea/
*.sublime-*

# 依赖
node_modules/
__pycache__/
*.pyc

# 备份文件
*.bak
*.backup

# 压缩文件
*.zip
*.tar.gz
*.rar
